{
  "name": "@nauta/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./geometry": {
      "types": "./dist/geometry.d.ts",
      "default": "./src/geometry.ts"
    },
    "./chat-canvas": {
      "types": "./dist/router/chat/canvas-schema.d.ts",
      "default": "./src/router/chat/canvas-schema.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nauta/db": "*",
    "@nauta/genui": "*",
    "@trpc/server": "11.8.0",
    "drizzle-orm": "^0.44.2",
    "superjson": "2.2.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^2.1.9"
  }
}
