{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@nauta/genui": ["./src/index.ts"],
      "@nauta/genui/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/__tests__"]
}
