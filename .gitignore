# Dev logs
.dev-logs/
tfplan*

.vercel

# Build artifacts
apps/web/.next/
# Verification builds (`npm run build:local`) target their own dir so they cannot
# clobber a live `next dev` server's chunks — see apps/web/next.config.mjs.
apps/web/.next-verify/
packages/api-client/dist/
*.tsbuildinfo

# Playwright artifacts
apps/web/test-results/
apps/web/playwright-report/

# Claude Code personal overrides
.claude/settings.local.json
apps/email-listener/listener-*.log

# Remote Control session log — contains a live session/environment URL
.planning/night-run/remote-control.log
.planning/night-run/resume-log.txt

# GSD plugin, vendored locally for this session (not a real /plugin install)
.claude/skills/*
!.claude/skills/polytoken-design-system/
.claude/agents/
.claude/gsd-support/

# Windows-path junk from daemon tests running on Linux (pre-existing win32 tests)
apps/daemon/\\tmp\\daemon-tools-*

# UI review captures — contain signed-in app state (docs/RUN-LOCAL + CLAUDE.md say gitignored; the rule was missing)
.planning/ui-reviews/

# Planning build artifacts & runtime files (untracked 2026-07-22)
.planning/graphs/graph.json
.planning/graphs/.last-build-snapshot.json
.planning/night-run/HEARTBEAT
.planning/.pending-auth-captures.jsonl
